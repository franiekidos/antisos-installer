#!/usr/bin/env python3
import sys
import json
import subprocess
from typing import List, Dict, Any

from textual.app import App, ComposeResult
from textual.containers import Vertical, Horizontal
from textual.widgets import Header, Footer, Button, Static, RadioSet, RadioButton

# Add /usr/share/antisos-installer to sys.path to import pages dynamically
sys.path.insert(0, "/usr/share/antisos-installer")

try:
    from pages.welcome import WelcomePage
    from pages.summary import SummaryPage
    from pages.install import InstallPage
except ModuleNotFoundError as e:
    print("Error: Could not import pages. Make sure /usr/share/antisos-installer/pages exists.")
    raise e

# Function to get disks using lsblk
def get_block_devices() -> List[Dict[str, Any]]:
    try:
        result = subprocess.run(
            ["lsblk", "-o", "NAME,SIZE,MODEL,TYPE", "-J"],
            capture_output=True,
            text=True,
            check=True,
        )
        data = json.loads(result.stdout)
        return data.get("blockdevices", [])
    except Exception as e:
        return [{"name": "error", "size": "0", "model": str(e), "type": "disk"}]

# Optional: a small page to select disk if you still want it
class SelectDiskPage(Vertical):
    """Optional disk selection page."""

    def __init__(self):
        super().__init__()
        self.devices = get_block_devices()

    def compose(self) -> ComposeResult:
        yield Static("Select target disk", id="part-title")
        with RadioSet(id="disk-radio"):
            for dev in self.devices:
                if dev["type"] == "disk":
                    label = f"/dev/{dev['name']} ({dev['size']} {dev.get('model','')})"
                    yield RadioButton(label)
        with Horizontal():
            yield Button("Advanced (GParted)", id="part-advanced")
            yield Button("Next", id="part-next")


class InstallerApp(App):
    CSS_PATH = "/usr/share/antisos-installer/css/installer.tcss"

    def __init__(self):
        super().__init__()
        self.current = None
        self.summary = None
        self.selected_disk = None

    def compose(self) -> ComposeResult:
        yield Header()
        self.main = Vertical(id="main")
        yield self.main
        yield Footer()

    def on_mount(self) -> None:
        self.show_welcome()

    def clear_main(self):
        if self.current:
            self.current.remove()

    # Show pages
    def show_welcome(self):
        self.clear_main()
        self.current = WelcomePage()
        self.main.mount(self.current)

    def show_select_disk(self):
        self.clear_main()
        self.current = SelectDiskPage()
        self.main.mount(self.current)

    def show_summary(self, disk: str):
        self.clear_main()
        self.summary = SummaryPage(disk)
        self.current = self.summary
        self.main.mount(self.current)

    def show_install(self, disk: str):
        self.clear_main()
        self.current = InstallPage(disk)
        self.main.mount(self.current)

    def on_button_pressed(self, event: Button.Pressed) -> None:
        btn = event.button.id
        if btn == "welcome-next":
            self.show_select_disk()
        elif btn == "part-next":
            disk_radio = self.query_one("#disk-radio", RadioSet)
            self.selected_disk = None
            for rb in disk_radio.query(RadioButton):
                if rb.value:
                    self.selected_disk = rb.label.plain
                    break
            if not self.selected_disk:
                self.selected_disk = "Unknown"
            self.show_summary(self.selected_disk)
        elif btn == "part-advanced":
            subprocess.run(["gparted"])
        elif btn == "summary-back":
            self.show_select_disk()
        elif btn == "summary-install":
            self.show_install(self.summary.disk)
        elif btn == "install-quit":
            self.exit()


if __name__ == "__main__":
    InstallerApp().run()